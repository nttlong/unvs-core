using NUnit.Framework;
using System;
using System.Collections.Generic;
using System.Linq;
using UnityEngine;
using UnityEngine.U2D.Animation;
using UnityEngine.U2D.IK;
using unvs.ext;

namespace unvs.players{
    public class PlayerBoneSolverChain:MonoBehaviour{
       


        public bool isMultiple;
        private void Reset()
        {
            GenerateSolveChain();
        }

        private void createSingle()
        {
            var ikManager = transform.CreateRootIKManager2DIfNotExist();

            var sovlers = ikManager.transform.parent.AddChildComponentIfNotExist<Transform>($"solver");
            sovlers.EditRemoveChildComponentIfExists<Transform>(name);
            var sovler = sovlers.AddChildComponentIfNotExist<Transform>($"{name}");
            var target = ikManager.transform.parent.AddChildComponentIfNotExist<Transform>($"targets");
            var root = ikManager.transform;
            var lst = new List<Transform>();
            var travel = transform;
            while (travel != root)
            {
                lst.Add(travel);
                travel = travel.parent;
            }
            lst.Reverse();
            
            foreach (Transform t in lst)
            {
                var s = ikManager.solvers.FirstOrDefault(p => p.name == t.name);
                if (s != null)
                {
                    ikManager.RemoveSolver(s);
                    sovler.EditRemoveChildComponentIfExists<FabrikSolver2D>(t.name);
                }

                currentTarget = currentTarget.AddChildComponentIfNotExist<Transform>(t.name);
            }
        }

        private void createMulti()
        {
           
           var ikManager = transform.CreateRootIKManager2DIfNotExist();
          
            var sovlers= ikManager.transform.parent.AddChildComponentIfNotExist<Transform>($"solver");
            sovlers.EditRemoveChildComponentIfExists<Transform>(name);
            var sovler= sovlers.AddChildComponentIfNotExist<Transform>($"{name}");
            var target = ikManager.transform.parent.AddChildComponentIfNotExist<Transform>($"targets");
            var root = ikManager.transform;
            var lst= new List<Transform>();
            var travel = transform;
            while (travel != root)
            {
                lst.Add(travel);
                travel = travel.parent;
            }
            lst.Reverse();
            Transform currentTarget = target;
            foreach (Transform t in lst)
            {
                var s=ikManager.solvers.FirstOrDefault(p => p.name == t.name);
                if (s != null)
                {
                    ikManager.RemoveSolver(s);
                    sovler.EditRemoveChildComponentIfExists<FabrikSolver2D>(t.name);
                }
                    
                currentTarget = currentTarget.AddChildComponentIfNotExist<Transform>(t.name);
            }
            foreach (Transform t in lst)
            {
                if (t.parent == root) continue;
               var s= sovler.AddChildComponentIfNotExist<FabrikSolver2D>(t.name);
                s.enabled = false;
                var ch = s.GetChain(0);
                if (ch == null)
                {
                    Debug.LogError($"{s.name} GetChain is null");
                   
                }
                ch.target = target.GetComponentInChildrenByName<Transform>(s.name);
                //ch.target.transform.position = bone.transform.position;
                ch.effector = t;
                ch.target.position = new Vector3(t.position.x, t.position.y, t.position.z);
                ch.transformCount = 2;
                ikManager.AddSolver(s);
            }
           
        }
#if UNITY_EDITOR
        public void GenerateSolveChain()
        {
            if (isMultiple)
                createMulti();
            else
                createSingle();
        }
#endif
    }
}