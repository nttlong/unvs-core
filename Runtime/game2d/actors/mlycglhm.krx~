using System;
using System.Linq;
using TMPro;
using UnityEngine;
using UnityEngine.InputSystem;
using UnityEngine.U2D.Animation;
using UnityEngine.UI;
using unvs.ext;

namespace unvs.game2d.actors
{
    public class IKBoneMap : UnvsBaseComponent
    {
        public Transform rootBone;
#if UNITY_EDITOR
        [UnvsButton ("Create IK Manager")]
        public void CreateIKManager()
        {
            this.rootBone = findRootBone();
            var anim = this.GetComponentInChildren<Animator>().transform;
            if (anim == null)
            {
                throw new Exception($"{typeof(Animator)} was not found in {name}");
            }
            this.ikControl = this.GetComponentInChildren<Animator>();

        }

        private Transform findRootBone()
        {
            var spriteSkins = this.GetComponentsInChildren<SpriteSkin>(true);
            return spriteSkins.SelectMany(p => p.boneTransforms).GetRoot();
        }
#endif
    }
}