        {
            "m_Id": "2b1c88a6e23d4cf380764b174ff008ea"
        },
        {
            "m_Id": "7bb5e390c5de4f658c94e2cbaa9276a0"
        },
        {
            "m_Id": "617ddfc5f0404c20b9a3240b8db43f41"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "WaveFunction",
    "m_FunctionSource": "407bc68d299748449bbf7f48ee690f8d",
    "m_FunctionBody": "// Tạo 2 lớp sóng lệch pha nhau để không bị lặp lại đơn điệu\r\nfloat s1 = sin(uv.x * freq + time * speed);\r\nfloat s2 = sin(uv.x * freq * 2.3 + time * speed * 1.7); // Sóng phụ nhỏ hơn\r\n\r\n// Kết hợp sóng và nhân với Amplitude\r\nfloat wave = (s1 + s2 * 0.4) * amp;\r\n\r\n// \"Khóa\" chân gỗ: Nếu uv.y = 0 (đáy), sóng = 0. Nếu uv.y = 1 (đỉnh), sóng mạnh nhất.\r\n// Cách này giúp cái gỗ trông như đang cắm vào bùn/nước.\r\nfloat anchor = pow(uv.y, 1.5); \r\n\r\noutPos = float3(pos.x, pos.y + (wave * anchor), pos.z);"
}

