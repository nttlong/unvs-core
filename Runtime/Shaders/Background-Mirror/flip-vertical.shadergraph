{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "47afc781192d4fa68380c4cf17170d2d",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "WaveFunction (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -1406.0,
            "y": -1587.9998779296875,
            "width": 236.0,
            "height": 398.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "a483ea040b22492d9dcdb38b4938b218"
        },
        {
            "m_Id": "d412abd9ed174406817c4f94eff403bf"
        },
        {
            "m_Id": "32ed3be202f3400e9d81c60fbe155aa1"
        },
        {
            "m_Id": "083f79442dbe4259970c124d8dc0a07a"
        },
        {
            "m_Id": "346ecaf837e74475b941fa966312ef9b"
        },
        {
            "m_Id": "c27fc18023774a798569c812e817b27c"
        },
        {
            "m_Id": "5d2c5b2536604ac6bbc64f87f400ef3c"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "WaveFunction",
    "m_FunctionSource": "407bc68d299748449bbf7f48ee690f8d",
    "m_FunctionBody": "// Tạo 2 lớp sóng lệch pha nhau để không bị lặp lại đơn điệu\r\nfloat s1 = sin(uv.x * freq + time * speed);\r\nfloat s2 = sin(uv.x * freq * 2.3 + time * speed * 1.7); // Sóng phụ nhỏ hơn\r\n\r\n// Kết hợp sóng và nhân với Amplitude\r\nfloat wave = (s1 + s2 * 0.4) * amp;\r\n\r\n// \"Khóa\" chân gỗ: Nếu uv.y = 0 (đáy), sóng = 0. Nếu uv.y = 1 (đỉnh), sóng mạnh nhất.\r\n// Cách này giúp cái gỗ trông như đang cắm vào bùn/nước.\r\nfloat anchor = pow(uv.y, 1.5); \r\n\r\noutPos = float3(pos.x, pos.y + (wave * anchor), pos.z);"
}

