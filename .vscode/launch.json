{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Debug FastAPI",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/Editor/python-libs~/api-server/main.py",
            "python": "${workspaceFolder}/Editor/python-libs~/venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}/Editor/python-libs~/api-server",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "python": "${workspaceFolder}/Editor/python-libs~/venv/Scripts/python.exe",
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}